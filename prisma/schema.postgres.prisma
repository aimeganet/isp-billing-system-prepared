generator client {
  provider = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

enum UserRoleKey {
  ADMIN
  SUPERVISOR
  EMPLOYEE
}

enum SubscriberStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum TransactionType {
  ACTIVATION
  RENEWAL
  DEPOSIT
  EXTRA_PACKAGE
  EXTRA_PACKAGE_RESET
}

enum TransactionMethodType {
  EMPLOYEE
  WALLET
}

enum InvoiceStatus {
  DRAFT
  PUBLISHED
  SENT
  FAILED
}

enum MessageChannel {
  WHATSAPP
  TELEGRAM
  NONE
}

enum MessageStatus {
  PENDING
  SENT
  FAILED
  SKIPPED
}

enum AttachmentKind {
  SCREENSHOT
  DOCUMENT
  IMPORT_SOURCE
}

enum ImportMode {
  UPDATE_EXISTING
  BULK_CREATE
}

enum ImportStatus {
  PENDING_REVIEW
  APPLYING
  COMPLETED
  FAILED
}

enum SyncStatus {
  PENDING
  PROCESSING
  SYNCED
  FAILED
}

model User {
  id            String      @id @default(cuid())
  name          String
  email         String      @unique
  passwordHash  String?
  role          UserRoleKey @default(EMPLOYEE)
  active        Boolean     @default(true)
  lastLoginAt   DateTime?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  sessions      Session[]
  userRoles     UserRole[]
  auditLogs     AuditLog[]
}

model Session {
  id         String   @id @default(cuid())
  token      String   @unique
  userId     String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model Role {
  id          String           @id @default(cuid())
  key         String           @unique
  name        String
  description String?
  active      Boolean          @default(true)
  isSystem    Boolean          @default(false)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  permissions RolePermission[]
  users       UserRole[]
}

model Permission {
  id          String           @id @default(cuid())
  key         String           @unique
  name        String
  description String?
  active      Boolean          @default(true)
  isSystem    Boolean          @default(false)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  roles       RolePermission[]

  @@index([active])
}

model RolePermission {
  id           String      @id @default(cuid())
  roleId       String
  permissionId String
  createdAt    DateTime    @default(now())

  role         Role        @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission  @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@index([roleId])
  @@index([permissionId])
}

model UserRole {
  id        String   @id @default(cuid())
  userId     String
  roleId     String
  createdAt  DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
  @@index([userId])
  @@index([roleId])
}

model Employee {
  id          String        @id @default(cuid())
  name        String
  slug        String        @unique
  roleLabel   String
  active      Boolean       @default(true)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  transactions Transaction[]
}

model WalletProvider {
  id                 String        @id @default(cuid())
  name               String
  code               String        @unique
  active             Boolean       @default(true)
  requiresScreenshot Boolean       @default(true)
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  transactions       Transaction[]
}

model PackagePlan {
  id            String       @id @default(cuid())
  name          String
  code          String       @unique
  gigabytes     Float
  durationDays  Int          @default(30)
  price         Float
  active        Boolean      @default(true)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  transactions  Transaction[]
  subscribers   Subscriber[]
}

model Subscriber {
  id                 String            @id @default(cuid())
  subscriberCode     String            @unique
  externalIdentifier String?
  name               String
  phone              String?
  status             SubscriberStatus  @default(ACTIVE)
  notes              String?
  currentPackageId   String?
  currentStartDate   DateTime?
  currentEndDate     DateTime?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  currentPackage     PackagePlan?      @relation(fields: [currentPackageId], references: [id])
  contacts           SubscriberContact[]
  transactions       Transaction[]
  invoices           Invoice[]
  usageLogs          UsageLog[]
  importRows         ImportRow[]
  messageLogs        MessageLog[]

  @@index([name])
  @@index([phone])
  @@index([status])
}

model SubscriberContact {
  id               String      @id @default(cuid())
  subscriberId     String
  label            String?
  phone            String
  whatsappEnabled  Boolean     @default(true)
  telegramEnabled  Boolean     @default(false)
  isPrimary        Boolean     @default(false)
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  subscriber       Subscriber  @relation(fields: [subscriberId], references: [id], onDelete: Cascade)

  @@index([subscriberId])
}

model Transaction {
  id               String                @id @default(cuid())
  transactionNo    String                @unique
  subscriberId     String
  packagePlanId    String?
  employeeId       String?
  walletProviderId String?
  type             TransactionType
  methodType       TransactionMethodType
  amount           Float
  excluded         Float                 @default(0)
  net              Float                 @default(0)
  notes            String?
  extraMode        String?
  occurredAt       DateTime              @default(now())
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt

  subscriber       Subscriber            @relation(fields: [subscriberId], references: [id], onDelete: Cascade)
  packagePlan      PackagePlan?          @relation(fields: [packagePlanId], references: [id])
  employee         Employee?             @relation(fields: [employeeId], references: [id])
  walletProvider   WalletProvider?       @relation(fields: [walletProviderId], references: [id])
  attachments      TransactionAttachment[]
  invoice          Invoice?

  @@index([subscriberId])
  @@index([type])
  @@index([occurredAt])
}

model TransactionAttachment {
  id            String         @id @default(cuid())
  transactionId String
  kind          AttachmentKind @default(SCREENSHOT)
  fileName      String
  filePath      String
  mimeType      String
  sizeBytes     Int
  createdAt     DateTime       @default(now())

  transaction   Transaction    @relation(fields: [transactionId], references: [id], onDelete: Cascade)

  @@index([transactionId])
}

model Invoice {
  id                  String         @id @default(cuid())
  invoiceNo           String         @unique
  subscriberId        String
  sourceTransactionId String?        @unique
  status              InvoiceStatus  @default(DRAFT)
  channel             MessageChannel @default(NONE)
  subtotal            Float
  total               Float
  notes               String?
  autoSendAttempted   Boolean        @default(false)
  messageSentAt       DateTime?
  publishedAt         DateTime?
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt

  subscriber          Subscriber     @relation(fields: [subscriberId], references: [id], onDelete: Cascade)
  sourceTransaction   Transaction?   @relation(fields: [sourceTransactionId], references: [id])
  items               InvoiceItem[]
  messageLogs         MessageLog[]

  @@index([subscriberId])
  @@index([status])
}

model InvoiceItem {
  id          String    @id @default(cuid())
  invoiceId    String
  label        String
  description  String?
  quantity     Float     @default(1)
  unitPrice    Float
  total        Float
  gigabytes    Float?
  createdAt    DateTime  @default(now())

  invoice      Invoice   @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
}

model UsageLog {
  id                 String      @id @default(cuid())
  subscriberId       String
  importRowId        String?     @unique
  usedGigabytes      Float?
  remainingGigabytes Float?
  notes              String?
  capturedAt         DateTime    @default(now())
  createdAt          DateTime    @default(now())

  subscriber         Subscriber  @relation(fields: [subscriberId], references: [id], onDelete: Cascade)
  importRow          ImportRow?  @relation(fields: [importRowId], references: [id])

  @@index([subscriberId])
}

model MessageTemplate {
  id         String         @id @default(cuid())
  name       String
  slug       String         @unique
  channel    MessageChannel
  eventKey   String
  content    String
  active     Boolean        @default(true)
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt
}

model MessageLog {
  id              String         @id @default(cuid())
  subscriberId    String?
  invoiceId       String?
  templateId      String?
  channel         MessageChannel
  phone           String
  renderedContent String
  providerRef     String?
  status          MessageStatus  @default(PENDING)
  errorMessage    String?
  createdAt       DateTime       @default(now())
  sentAt          DateTime?

  subscriber      Subscriber?    @relation(fields: [subscriberId], references: [id])
  invoice         Invoice?       @relation(fields: [invoiceId], references: [id])
}

model SystemSetting {
  id          String   @id @default(cuid())
  key         String   @unique
  value       String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ImportJob {
  id           String       @id @default(cuid())
  fileName     String
  fileType     String
  sourcePath   String?
  mode         ImportMode
  status       ImportStatus @default(PENDING_REVIEW)
  totalRows    Int          @default(0)
  createdRows  Int          @default(0)
  updatedRows  Int          @default(0)
  failedRows   Int          @default(0)
  notes        String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  rows         ImportRow[]
}

model ImportRow {
  id                  String      @id @default(cuid())
  importJobId         String
  rowIndex            Int
  rawText             String
  parsedName          String?
  parsedPhone         String?
  usedGigabytes       Float?
  remainingGigabytes  Float?
  matchedSubscriberId String?
  applyStatus         String      @default("PENDING")
  resultMessage       String?
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt

  importJob           ImportJob   @relation(fields: [importJobId], references: [id], onDelete: Cascade)
  matchedSubscriber   Subscriber? @relation(fields: [matchedSubscriberId], references: [id])
  usageLog            UsageLog?

  @@index([importJobId])
}

model AuditLog {
  id          String   @id @default(cuid())
  userId      String?
  action      String
  entityType  String
  entityId    String
  payloadJson String?
  createdAt   DateTime @default(now())

  user        User?    @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([entityType, entityId])
}

model SyncQueue {
  id          String     @id @default(cuid())
  entityType  String
  entityId    String
  operation   String
  payloadJson String
  status      SyncStatus @default(PENDING)
  attempts    Int        @default(0)
  lastError   String?
  availableAt DateTime   @default(now())
  syncedAt    DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([status, availableAt])
}
